{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Heraldic Object Model (HOM)",
  "description": "Standardized JSON schema representing a parsed heraldic device for evaluation and rendering.",
  "type": "object",
  "properties": {
    "version": { "type": "string", "default": "1.1" },
    "authority_context": {
      "type": "string",
      "description": "The heraldic college/authority defining the ruleset (e.g., 'SENA', 'British_CoA', 'Fictional_Generic').",
      "default": "generic"
    },
    "layout_type": {
      "type": "string",
      "enum": ["simple", "marshalled", "impaled", "quarterly"],
      "default": "simple"
    },
    "field": {
      "type": "object",
      "properties": {
        "is_divided": { "type": "boolean" },
        "division_type": { "type": ["string", "null"] },
        "tinctures": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "required": ["is_divided", "tinctures"]
    },
    "charge_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "group_type": {
            "type": "string",
            "enum": ["primary", "secondary", "tertiary", "overall"]
          },
          "charges": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "category": { "type": "string" },
                "specific_type": { "type": "string" },
                "conflict_id": { "type": ["string", "null"] },
                "number": { "type": "integer", "minimum": 1 },
                "tincture": { "type": "string" },
                "posture": { "type": ["string", "null"] },
                "orientation": { "type": ["string", "null"] },
                "details": { "type": "object", "additionalProperties": true }
              },
              "required": ["category", "specific_type", "number", "tincture"]
            }
          }
        },
        "required": ["group_type", "charges"]
      }
    },
    "augmentations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["field", "charge_groups"]
}
